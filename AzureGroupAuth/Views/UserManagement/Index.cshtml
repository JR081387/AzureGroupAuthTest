@model Dictionary<string, List<AzureGroupAuth.Services.GroupMember>>
@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-4">
    <h2>User Management</h2>
    <p class="text-muted">View users with access to this application. To add or remove users, visit the <a href="https://portal.azure.com/#view/Microsoft_AAD_IAM/GroupsManagementMenuBlade/~/AllGroups" target="_blank">Azure Portal</a>.</p>

    <div class="alert alert-info">
        <strong>Note:</strong> This is a read-only view. To manage users and group memberships, you must use the Azure Portal.
    </div>

    @foreach (var group in Model)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">@group.Key</h4>
                <span class="badge bg-primary">@group.Value.Count user(s)</span>
            </div>
            <div class="card-body p-0">
                @if (group.Value.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Display Name</th>
                                <th>Email</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in group.Value.OrderBy(m => m.DisplayName))
                            {
                                <tr>
                                    <td>@member.DisplayName</td>
                                    <td>@member.Email</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="p-3 text-muted">No users in this group.</p>
                }
            </div>
        </div>
    }

    <div class="mt-3 d-flex gap-2">
        <a href="https://portal.azure.com/#view/Microsoft_AAD_IAM/GroupsManagementMenuBlade/~/AllGroups"
           target="_blank"
           class="btn btn-primary">
            Manage Users in Azure Portal
        </a>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
