<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Identity" Version="1.18.0" />
    <PackageReference Include="Microsoft.Graph" Version="5.*" />
    <PackageReference Include="Microsoft.Identity.Web" Version="4.*" />
    <PackageReference Include="Microsoft.Identity.Web.UI" Version="4.*" />
  </ItemGroup>

  <!-- Exclude AuthTemplates from compilation - they are reference/template files only -->
  <ItemGroup>
    <Compile Remove="AuthTemplates\**" />
    <Content Remove="AuthTemplates\**" />
    <None Include="AuthTemplates\**" />
  </ItemGroup>

</Project>
