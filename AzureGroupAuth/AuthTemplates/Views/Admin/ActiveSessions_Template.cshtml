@model List<SOWTracker.Models.UserSession>

@{
    ViewData["Title"] = "Active Sessions";
}

<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Active Sessions</h5>
        <span class="text-muted">
            <strong>@ViewBag.ActiveCount</strong> active of <strong>@ViewBag.TotalTracked</strong> tracked
        </span>
    </div>
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <div class="p-4 text-center text-muted">
                No active sessions found.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40px;"></th>
                            <th>User</th>
                            <th>Email</th>
                            <th>Login Time</th>
                            <th>Last Activity</th>
                            <th>IP Address</th>
                            <th>Browser</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in Model)
                        {
                            var isActive = session.IsActive(15);
                            <tr>
                                <td class="text-center">
                                    @if (isActive)
                                    {
                                        <span class="d-inline-block rounded-circle" style="width: 10px; height: 10px; background-color: #28a745;" title="Active"></span>
                                    }
                                    else
                                    {
                                        <span class="d-inline-block rounded-circle" style="width: 10px; height: 10px; background-color: #6c757d;" title="Idle"></span>
                                    }
                                </td>
                                <td>@session.DisplayName</td>
                                <td>@session.Email</td>
                                <td>@session.LoginTime.ToString("MMM dd, yyyy h:mm tt") UTC</td>
                                <td>
                                    @{
                                        var elapsed = DateTime.UtcNow - session.LastActivity;
                                        string relativeTime;
                                        if (elapsed.TotalSeconds < 60)
                                            relativeTime = "Just now";
                                        else if (elapsed.TotalMinutes < 60)
                                            relativeTime = $"{(int)elapsed.TotalMinutes} min ago";
                                        else
                                            relativeTime = $"{(int)elapsed.TotalHours}h {elapsed.Minutes}m ago";
                                    }
                                    @relativeTime
                                </td>
                                <td><code>@session.IpAddress</code></td>
                                <td>@ParseBrowser(session.UserAgent)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    string ParseBrowser(string userAgent)
    {
        if (string.IsNullOrEmpty(userAgent)) return "Unknown";
        if (userAgent.Contains("Edg/")) return "Edge";
        if (userAgent.Contains("Chrome/")) return "Chrome";
        if (userAgent.Contains("Firefox/")) return "Firefox";
        if (userAgent.Contains("Safari/")) return "Safari";
        return "Other";
    }
}
